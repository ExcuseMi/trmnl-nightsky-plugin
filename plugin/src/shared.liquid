{% template main %}
{% assign moon_id  = "moon-"  | append_random %}
{% assign mf_class = "mf-"    | append_random %}
{% assign pl_id    = "pl-"    | append_random %}
{% assign show_info         = trmnl.plugin_settings.custom_fields_values.show_info_panel %}
{% assign show_planet_names = trmnl.plugin_settings.custom_fields_values.show_planet_names %}
{% assign show_title_bar    = trmnl.plugin_settings.custom_fields_values.show_title_bar | default: "true" %}
{% assign time_format       = trmnl.plugin_settings.custom_fields_values.time_format | default: "24h" %}

{% if time_format == "12h" %}
  {% assign time_format_str = "%I:%M %P" %}
{% else %}
  {% assign time_format_str = "%H:%M" %}
{% endif %}

<style>
  .ns-overlay {
    position: absolute;
    top: 8px;
    right: 8px;
    background: white;
    border: 2px solid black;
    border-radius: 6px;
    padding: 7px 10px;
    z-index: 100;
    min-width: 210px;
    max-width: 260px;
  }
  .ns-day-label { font-size: 8px; }
  @container (min-width: 1024px) {
    .ns-overlay { min-width: 260px; max-width: 320px; }
    .ns-day-label { font-size: 10px; }
  }
</style>

<div class="layout gap--none m--0 p--0 layout--stretch">

  {% assign cw = data.sky.chart_w | default: 800 %}
  {% assign ch = data.sky.chart_h | default: 480 %}
    <svg id="{{ pl_id }}" xmlns="http://www.w3.org/2000/svg"
         viewBox="0 0 {{ cw }} {{ ch }}"
         preserveAspectRatio="xMidYMid slice"
         class="image image--cover 1bit:image-dither w--full h--full"
         >
      {% if data.sky.chart != "" %}
        <image href="{{ data.sky.chart }}" x="0" y="0" width="{{ cw }}" height="{{ ch }}" preserveAspectRatio="none"/>
      {% else %}
        <rect width="{{ cw }}" height="{{ ch }}" fill="black"/>
      {% endif %}
    </svg>

    {% if show_info == "true" %}

      {% if view == 1 %}

        <div class="ns-overlay">

          <span class="label label--underline lg:label--large">{{ data.viewing.date }}</span>

          <div class="flex gap--small align--center">
            <span class="title lg:title--large">{{ data.viewing.verdict }}</span>
            {% if data.viewing.best_from %}
              <span class="label label--small lg:label" style="margin-left:auto;flex-shrink:0">★ {{ data.viewing.best_from | plus: trmnl.user.utc_offset | date: time_format_str }}</span>
            {% endif %}
          </div>
          <span class="label label--small lg:label">Bortle {{ data.sky.bortle }} · {{ data.sky.bortle_label }} · NELM {{ data.sky.nelm }}</span>

          <div class="divider"></div>

          <div class="flex gap--small align--center">
            <img id="{{ moon_id }}" style="width:32px;height:32px;flex-shrink:0" alt="moon">
            <div class="flex flex--col gap--[2px]">
              <span class="label lg:label--large">{{ data.moon.phase }} {{ data.moon.illumination }}%</span>
              <span class="label label--small lg:label--base">
                {% if data.moon.rises %}↑{{ data.moon.rises | plus: trmnl.user.utc_offset | date: time_format_str }}{% endif %}
                {% if data.moon.sets %} ↓{{ data.moon.sets | plus: trmnl.user.utc_offset | date: time_format_str }}{% endif %}
              </span>
            </div>
          </div>

          <div class="divider"></div>

          <div class="flex flex--col gap--[3px]">
            <span class="label label--small lg:label--base"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" width="11" height="11" style="vertical-align:-2px;display:inline-block"><circle cx="6" cy="6" r="2.5" fill="currentColor"/><line x1="6" y1="0.5" x2="6" y2="2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="6" y1="9.5" x2="6" y2="11.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="0.5" y1="6" x2="2.5" y2="6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="9.5" y1="6" x2="11.5" y2="6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg> ↓{{ data.sun.sets | plus: trmnl.user.utc_offset | date: time_format_str }} ↑{{ data.sun.rises | plus: trmnl.user.utc_offset | date: time_format_str }}{% if data.moon.sets %} · <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" width="10" height="11" style="vertical-align:-2px;display:inline-block"><defs><mask id="{{ pl_id }}-mc"><rect width="12" height="12" fill="white"/><circle cx="7.5" cy="4.5" r="4.5" fill="black"/></mask></defs><circle cx="5" cy="6.5" r="5" fill="currentColor" mask="url(#{{ pl_id }}-mc)"/></svg> ↓{{ data.moon.sets | plus: trmnl.user.utc_offset | date: time_format_str }}{% endif %}</span>
            <span class="label label--small lg:label--base"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 7 13" width="7" height="12" style="vertical-align:-2px;display:inline-block"><rect x="2" y="0" width="3" height="7.5" rx="1.5" fill="currentColor"/><rect x="2.5" y="5.5" width="2" height="4" fill="currentColor"/><circle cx="3.5" cy="10.5" r="2.5" fill="currentColor"/></svg> {{ data.forecast.now.temp }}°C · <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 10 12" width="8" height="12" style="vertical-align:-2px;display:inline-block"><path d="M5 1C3 4 1 7 1 9a4 4 0 0 0 8 0C9 7 7 4 5 1Z" fill="currentColor"/></svg> {{ data.forecast.now.dew_point }}°C · <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 8" width="12" height="8" style="vertical-align:-1px;display:inline-block"><line x1="0.5" y1="2" x2="11.5" y2="2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="0.5" y1="6" x2="8.5" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> {{ data.forecast.now.wind_dir }} {{ data.forecast.now.wind_speed }} km/h</span>
            <span class="label label--small lg:label--base">RH {{ data.forecast.now.humidity }}% · ☁ L{{ data.forecast.now.cloud_low }}% M{{ data.forecast.now.cloud_mid }}% H{{ data.forecast.now.cloud_high }}%</span>
          </div>

          <div class="divider"></div>

          <div class="flex gap--[6px]">
            {% for day in data.moon.days %}
              <div class="flex flex--col gap--[2px] align--center" style="flex:1">
                <img class="{{ mf_class }}"
                     data-illum="{{ day.illumination }}"
                     data-waxing="{{ day.waxing }}"
                     style="width:28px;height:28px" alt="{{ day.phase }}">
                <span class="label label--small ns-day-label" style="text-align:center">{{ day.label }}</span>
                <span class="label label--small ns-day-label" style="text-align:center">{{ day.illumination }}%</span>
              </div>
            {% endfor %}
          </div>

          <div class="divider"></div>

          {% if data.planets.size > 0 %}
            <div class="flex flex--col gap--[3px]">
              {% for planet in data.planets limit: 4 %}
                <div class="flex gap--small w--full">
                  <span class="label label--small lg:label--base" style="flex:1;min-width:0">{{ planet.name }} {{ planet.dir }} {{ planet.alt }}°</span>
                  <span class="label label--small lg:label--base" style="color:#555;flex-shrink:0">mag {{ planet.mag }} · {{ planet.constellation }}</span>
                </div>
              {% endfor %}
            </div>
          {% endif %}

        </div>

      {% elsif view == 2 %}

        <div class="ns-overlay">
          <span class="label label--underline lg:title">{{ data.viewing.date }}</span>
          <div class="divider"></div>
          <div class="flex gap--small align--center">
            <img id="{{ moon_id }}" style="width:32px;height:32px;flex-shrink:0" alt="moon">
            <div class="flex flex--col gap--[2px]">
              <span class="title lg:title--large">{{ data.viewing.verdict }}</span>
              <span class="label label--small lg:label--base">{{ data.moon.phase }} {{ data.moon.illumination }}%</span>
            </div>
          </div>
          <div class="divider"></div>
          <div class="flex flex--col gap--[3px]">
            <span class="label label--small lg:label--base">Bortle {{ data.sky.bortle }} · NELM {{ data.sky.nelm }}</span>
            <span class="label label--small lg:label--base"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" width="11" height="11" style="vertical-align:-2px;display:inline-block"><circle cx="6" cy="6" r="2.5" fill="currentColor"/><line x1="6" y1="0.5" x2="6" y2="2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="6" y1="9.5" x2="6" y2="11.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="0.5" y1="6" x2="2.5" y2="6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="9.5" y1="6" x2="11.5" y2="6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg> ↓{{ data.sun.sets | plus: trmnl.user.utc_offset | date: time_format_str }} ↑{{ data.sun.rises | plus: trmnl.user.utc_offset | date: time_format_str }} · ☁ {{ data.forecast.now.cloud }}% · <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 7 13" width="7" height="12" style="vertical-align:-2px;display:inline-block"><rect x="2" y="0" width="3" height="7.5" rx="1.5" fill="currentColor"/><rect x="2.5" y="5.5" width="2" height="4" fill="currentColor"/><circle cx="3.5" cy="10.5" r="2.5" fill="currentColor"/></svg> {{ data.forecast.now.temp }}°C</span>
            {% if data.planets.size > 0 %}
              <span class="label label--small lg:label--base">{% for planet in data.planets limit: 3 %}{{ planet.name }} {{ planet.dir }} {{ planet.alt }}°{% unless forloop.last %} · {% endunless %}{% endfor %}</span>
            {% endif %}
          </div>
        </div>

      {% elsif view == 3 %}

        <div class="ns-overlay">
          <span class="label label--underline lg:label--large">{{ data.viewing.date }}</span>
          <div class="divider"></div>
          <div class="flex gap--small align--center">
            <img id="{{ moon_id }}" style="width:32px;height:32px;flex-shrink:0" alt="moon">
            <div class="flex flex--col gap--[2px]">
              <span class="title lg:title--large">{{ data.viewing.verdict }}</span>
              <span class="label label--small lg:label--base">{{ data.moon.phase }} {{ data.moon.illumination }}%</span>
            </div>
          </div>
          <div class="divider"></div>
          <span class="label label--small lg:label">Bortle {{ data.sky.bortle }} · ☁ {{ data.forecast.now.cloud }}% · {{ data.forecast.now.temp }}°C</span>
        </div>

      {% elsif view == 4 %}

        <div class="ns-overlay" style="min-width:0;padding:5px 8px">
          <span class="label label--underline" style="display:block;margin-bottom:3px">{{ data.viewing.date }}</span>
          <div class="flex gap--small align--center">
            <img id="{{ moon_id }}" style="width:24px;height:24px;flex-shrink:0" alt="moon">
            <div class="flex flex--col gap--[2px]">
              <span class="label lg:title">{{ data.viewing.verdict }}</span>
              <span class="label label--small lg:label">{{ data.moon.illumination }}% · ☁ {{ data.forecast.now.cloud }}%</span>
            </div>
          </div>
        </div>

      {% endif %}

    {% endif %}



  </div>
    {% if show_title_bar == "true" %}
    <div class="title_bar">
      <svg class="image h--8 w--8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
        <defs><mask id="ns-crescent"><rect width="512" height="512" fill="white"/><circle cx="306" cy="218" r="178" fill="black"/></mask></defs>
        <circle cx="238" cy="256" r="212" fill="black" mask="url(#ns-crescent)"/>
        <circle cx="404" cy="76" r="24" fill="black"/>
        <circle cx="468" cy="192" r="15" fill="black"/>
        <circle cx="372" cy="22" r="15" fill="black"/>
      </svg>
      <span class="title">{{ trmnl.plugin_settings.instance_name | default: "Night Sky"}}</span>
      <span class="instance" style="margin-left:auto">
        {% if data.sky.location %}{{ data.sky.location }} · {% endif %}
        {{ data.viewing.chart_epoch | plus: trmnl.user.utc_offset | date: time_format_str }}
      </span>
    </div>
    {% endif %}
<script>
(function() {
  var moonId  = '{{ moon_id }}';
  var mfClass = '{{ mf_class }}';

  function moonShape(illum, isWaxing, r, c) {
    if (illum <= 2)  return '<circle cx="'+c+'" cy="'+c+'" r="'+r+'" fill="black" stroke="black" stroke-width="2"/>';
    if (illum >= 98) return '<circle cx="'+c+'" cy="'+c+'" r="'+r+'" fill="white" stroke="black" stroke-width="2"/>';
    var frac = illum / 100;
    var ex = Math.round(r * Math.abs(1 - 2 * frac) * 10) / 10;
    var bs = isWaxing ? 1 : 0, ts = frac < 0.5 ? bs : (1 - bs);
    var d = 'M '+c+','+(c-r)+' A '+r+' '+r+' 0 0 '+bs+' '+c+','+(c+r)+' A '+ex+' '+r+' 0 0 '+ts+' '+c+','+(c-r)+' Z';
    return '<circle cx="'+c+'" cy="'+c+'" r="'+r+'" fill="black" stroke="black" stroke-width="2"/><path d="'+d+'" fill="white"/>';
  }

  function moonSrc(illum, isWaxing, r, c) {
    var size = c * 2;
    var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 '+size+' '+size+'">'+moonShape(illum, isWaxing, r, c)+'</svg>';
    return 'data:image/svg+xml;base64,' + btoa(svg);
  }

  var illum    = {{ data.moon.illumination | default: 0 }};
  var isWaxing = /Waxing|New Moon|First Quarter/.test({{ data.moon.phase | json }});

  var el = document.getElementById(moonId);
  if (el) el.src = moonSrc(illum, isWaxing, 38, 40);

  document.querySelectorAll('.' + mfClass).forEach(function(img) {
    var i = parseInt(img.getAttribute('data-illum') || '0');
    var w = img.getAttribute('data-waxing') === 'true';
    img.src = moonSrc(i, w, 24, 26);
  });
})();

// Reserve sun/moon areas in collision grid
(function() {
  var svg = document.getElementById('{{ pl_id }}');
  if (!svg) return;
  var placed = svg._nsPlaced || [];
  svg._nsPlaced = placed;

  function reserveXY(x, y, size) {
    if (x == null || y == null) return;
    var r = {x: x - size/2, y: y - size/2, w: size, h: size};
    placed.push(r);
  }

  var daytimeMode = {{ trmnl.plugin_settings.custom_fields_values.daytime_mode | json }};
  if (daytimeMode !== 'ignore') {
    reserveXY({{ data.sun.x | default: 'null' }}, {{ data.sun.y | default: 'null' }}, 60);
  }
  reserveXY({{ data.moon.x | default: 'null' }}, {{ data.moon.y | default: 'null' }}, 50);
})();

// Constellation lines + labels
(function() {
  var svg = document.getElementById('{{ pl_id }}');
  if (!svg) return;
  var W = {{ cw }}, H = {{ ch }};
  var ns = 'http://www.w3.org/2000/svg';
  var consts = {{ data.constellations | json }};
  if (!consts || !consts.length) return;

  var placed = svg._nsPlaced || [];
  svg._nsPlaced = placed;

  var lineColor = 'rgba(255,255,255,0.28)';
  var textFill  = 'rgba(255,255,255,0.85)';
  var bgFill    = 'rgba(0,0,0,0.6)';
  var font = 'var(--title-bar-font-family, var(--title-font-family, "NicoClear", monospace))';

  function overlaps(r) {
    return placed.some(function(e) {
      return r.x < e.x+e.w+5 && r.x+r.w+5 > e.x && r.y < e.y+e.h+5 && r.y+r.h+5 > e.y;
    });
  }

  // 1. Draw all lines first
  consts.forEach(function(c) {
    c.ls.forEach(function(s) {
      var line = document.createElementNS(ns, 'line');
      line.setAttribute('x1', s[0].toFixed(1));
      line.setAttribute('y1', s[1].toFixed(1));
      line.setAttribute('x2', s[2].toFixed(1));
      line.setAttribute('y2', s[3].toFixed(1));
      line.setAttribute('stroke', lineColor);
      line.setAttribute('stroke-width', '1.1');
      svg.appendChild(line);
    });
  });

  // 2. Draw all labels on top
  consts.forEach(function(c) {
    if (c.x === undefined) return;
    var tx = c.x, ty = c.y;
    var t = document.createElementNS(ns, 'text');
    t.setAttribute('x', tx.toFixed(1)); t.setAttribute('y', ty.toFixed(1));
    t.setAttribute('text-anchor', 'middle'); t.setAttribute('dominant-baseline', 'middle');
    t.setAttribute('font-size', '10'); t.setAttribute('fill', textFill);
    t.setAttribute('font-family', font);
    t.textContent = c.n;
    svg.appendChild(t);

    var tw = t.getComputedTextLength() || (c.n.length * 6);
    var pad = 6, lh = 14;
    var r = {x: tx - tw/2 - pad/2, y: ty - lh/2, w: tw + pad, h: lh};

    if (overlaps(r)) {
      svg.removeChild(t);
    } else {
      placed.push(r);
      var bg = document.createElementNS(ns, 'rect');
      bg.setAttribute('x', r.x.toFixed(1)); bg.setAttribute('y', r.y.toFixed(1));
      bg.setAttribute('width', r.w.toFixed(1)); bg.setAttribute('height', r.h.toFixed(1));
      bg.setAttribute('fill', bgFill); bg.setAttribute('rx', '2');
      svg.insertBefore(bg, t);
    }
  });
})();

// Planet dots + leader lines
(function() {
  var svg = document.getElementById('{{ pl_id }}');
  if (!svg) return;
  var W = {{ cw }}, H = {{ ch }};
  var ns = 'http://www.w3.org/2000/svg';
  var planets = [{% for pl in data.planets %}{"n":"{{ pl.name }}","x":{{ pl.x | default: 'null' }},"y":{{ pl.y | default: 'null' }},"m":{{ pl.mag }}}{% unless forloop.last %},{% endunless %}{% endfor %}];
  var showPlanetNames = (function() { var v = '{{ show_planet_names }}'; return v === 'yes' || v === 'true'; })();
  var placed = svg._nsPlaced || [];
  var ANCHORS = [{ax:0,ay:-1},{ax:1,ay:-1},{ax:1,ay:0},{ax:1,ay:1},{ax:0,ay:1},{ax:-1,ay:1},{ax:-1,ay:0},{ax:-1,ay:-1}];
  var AR = 18;
  var font = 'var(--title-bar-font-family, var(--title-font-family, "NicoClear", monospace))';

  var dotFill   = 'white';
  var dotStroke = 'rgba(255,255,255,0.4)';
  var leaderClr = 'rgba(255,255,255,0.35)';
  var labelBg   = 'rgba(0,0,0,0.65)';
  var labelClr  = 'white';

  function hits(r) {
    return placed.some(function(e) {
      function check(r1, r2) {
        return r1.x < r2.x+r2.w+3 && r1.x+r1.w+3 > r2.x && r1.y < r2.y+r2.h+3 && r1.y+r1.h+3 > r2.y;
      }
      return check(r, e);
    });
  }

  planets.forEach(function(pl) {
    var px = pl.x, py = pl.y;
    if (px == null || py == null) return;
    var mag = parseFloat(pl.m);
    var pr  = Math.max(1.5, Math.min(4.5, 3.5 - mag * 0.5));
    var dot = document.createElementNS(ns, 'circle');
    dot.setAttribute('cx', px.toFixed(1)); dot.setAttribute('cy', py.toFixed(1));
    dot.setAttribute('r', pr.toFixed(1)); dot.setAttribute('fill', dotFill);
    dot.setAttribute('stroke', dotStroke); dot.setAttribute('stroke-width', '1');
    svg.appendChild(dot);
    
    var dr = {x: px-pr-1, y: py-pr-1, w: (pr+1)*2, h: (pr+1)*2};
    placed.push(dr);

    if (!showPlanetNames) return;

    var lw = pl.n.length * 6.5 + 8, lh = 14, anchor = null;
    for (var i = 0; i < ANCHORS.length; i++) {
      var a = ANCHORS[i];
      var lx = px + a.ax*AR - (a.ax < 0 ? lw : (a.ax === 0 ? lw/2 : 0));
      var ly = py + a.ay*AR - (a.ay < 0 ? lh : (a.ay === 0 ? lh/2 : 0));
      if (lx < 2 || lx+lw > W-2 || ly < 2 || ly+lh > H-2) continue;
      var r = {x:lx, y:ly, w:lw, h:lh};
      if (!hits(r)) { anchor = {x:lx, y:ly, r:r}; break; }
    }
    if (!anchor) return;
    placed.push(anchor.r);

    var lcx = anchor.x + lw/2, lcy = anchor.y + lh/2;
    var dx = lcx - px, dy = lcy - py, d = Math.sqrt(dx*dx+dy*dy) || 1;
    var line = document.createElementNS(ns, 'line');
    line.setAttribute('x1', (px+dx/d*5).toFixed(1)); line.setAttribute('y1', (py+dy/d*5).toFixed(1));
    line.setAttribute('x2', lcx.toFixed(1)); line.setAttribute('y2', lcy.toFixed(1));
    line.setAttribute('stroke', leaderClr); line.setAttribute('stroke-width', '1');
    line.setAttribute('stroke-dasharray', '3 2');
    svg.appendChild(line);

    var bg = document.createElementNS(ns, 'rect');
    bg.setAttribute('x', anchor.x.toFixed(1)); bg.setAttribute('y', anchor.y.toFixed(1));
    bg.setAttribute('width', lw.toFixed(1)); bg.setAttribute('height', lh.toFixed(1));
    bg.setAttribute('fill', labelBg); bg.setAttribute('rx', '2');
    svg.appendChild(bg);

    var t = document.createElementNS(ns, 'text');
    t.setAttribute('x', (anchor.x+3).toFixed(1)); t.setAttribute('y', (anchor.y+11).toFixed(1));
    t.setAttribute('font-size', '11'); t.setAttribute('fill', labelClr);
    t.setAttribute('font-weight', 'bold'); t.setAttribute('font-family', font);
    t.textContent = pl.n;
    svg.appendChild(t);
  });
})();
</script>
{% endtemplate %}
