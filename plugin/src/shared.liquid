{% template main %}
{% assign moon_id  = "moon-"  | append_random %}
{% assign mf_class = "mf-"    | append_random %}

{% if view == 1 %}

<style>
  .ns-overlay {
    position: absolute;
    top: 8px;
    right: 8px;
    background: white;
    border: 2px solid black;
    border-radius: 6px;
    padding: 7px 10px;
    z-index: 100;
    min-width: 210px;
    max-width: 260px;
  }
  .ns-bar-row { display: flex; align-items: flex-end; gap: 2px; }
  .ns-bar-label { width: 46px; flex-shrink: 0; align-self: center; }
  .ns-bar { flex: 1; border: 1px solid #ccc; min-height: 2px; }
</style>

<div class="layout layout--stretch">

  {% comment %} ── Full-screen sky chart ── {% endcomment %}
  {% if data.sky.chart != "" %}
    <img src="{{ data.sky.chart }}"
         style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:fill;display:block">
  {% else %}
    <div style="position:absolute;top:0;left:0;width:100%;height:100%;background:black"></div>
  {% endif %}

  {% comment %} ── Stats overlay (top-right) ── {% endcomment %}
  <div class="ns-overlay">

    {% comment %} Verdict + best from {% endcomment %}
    <div class="flex gap--small align--center">
      <span class="title lg:title--large" style="flex-shrink:0">{{ data.viewing.stars_text }}</span>
      <span class="title lg:title--large">{{ data.viewing.verdict }}</span>
      {% if data.viewing.best_from %}
        <span class="label label--small lg:label" style="margin-left:auto;flex-shrink:0">★ {{ data.viewing.best_from }}</span>
      {% endif %}
    </div>
    <span class="label label--small">Bortle {{ data.sky.bortle }} · {{ data.sky.bortle_label }} · NELM {{ data.sky.nelm }}</span>

    <div class="divider"></div>

    {% comment %} Moon {% endcomment %}
    <div class="flex gap--small align--center">
      <img id="{{ moon_id }}" style="width:32px;height:32px;flex-shrink:0" alt="moon">
      <div class="flex flex--col gap--[2px]">
        <span class="label lg:description">{{ data.moon.phase }} {{ data.moon.illumination }}%</span>
        <span class="label label--small">
          {% if data.moon.rises %}↑{{ data.moon.rises }}{% endif %}
          {% if data.moon.sets %} ↓{{ data.moon.sets }}{% endif %}
        </span>
      </div>
    </div>

    <div class="divider"></div>

    {% comment %} Hourly forecast bars {% endcomment %}
    <div class="flex gap--[2px]" style="margin-bottom:2px">
      <div style="width:46px;flex-shrink:0"></div>
      {% for h in data.forecast.hourly %}
        <div style="flex:1;text-align:center"><span class="label label--small" style="font-size:8px">{{ h.hour }}</span></div>
      {% endfor %}
    </div>

    <div class="ns-bar-row">
      <div class="ns-bar-label"><span class="label label--small">☁</span></div>
      {% for h in data.forecast.hourly %}
        {% assign bh = h.cloud | times: 28 | divided_by: 100 %}
        {% if h.cloud > 75 %}{% assign bg = "black" %}{% elsif h.cloud > 30 %}{% assign bg = "#888" %}{% else %}{% assign bg = "#ddd" %}{% endif %}
        <div class="ns-bar" style="height:{{ bh | at_least: 2 }}px;background:{{ bg }}"></div>
      {% endfor %}
    </div>

    {% assign has_seeing = false %}
    {% for h in data.forecast.hourly %}{% if h.seeing > 0 %}{% assign has_seeing = true %}{% endif %}{% endfor %}
    {% if has_seeing %}
      <div class="ns-bar-row" style="margin-top:2px">
        <div class="ns-bar-label"><span class="label label--small">👁</span></div>
        {% for h in data.forecast.hourly %}
          {% if h.seeing > 0 %}
            {% assign bh = h.seeing | minus: 1 | times: 28 | divided_by: 7 %}
            {% if h.seeing >= 6 %}{% assign bg = "black" %}{% elsif h.seeing >= 4 %}{% assign bg = "#888" %}{% else %}{% assign bg = "#ddd" %}{% endif %}
            <div class="ns-bar" style="height:{{ bh | at_least: 2 }}px;background:{{ bg }}"></div>
          {% else %}
            <div class="ns-bar" style="height:2px;background:#eee"></div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% assign has_transp = false %}
    {% for h in data.forecast.hourly %}{% if h.transparency > 0 %}{% assign has_transp = true %}{% endif %}{% endfor %}
    {% if has_transp %}
      <div class="ns-bar-row" style="margin-top:2px">
        <div class="ns-bar-label"><span class="label label--small">✦</span></div>
        {% for h in data.forecast.hourly %}
          {% if h.transparency > 0 %}
            {% assign bh = h.transparency | minus: 1 | times: 28 | divided_by: 7 %}
            {% if h.transparency >= 6 %}{% assign bg = "black" %}{% elsif h.transparency >= 4 %}{% assign bg = "#888" %}{% else %}{% assign bg = "#ddd" %}{% endif %}
            <div class="ns-bar" style="height:{{ bh | at_least: 2 }}px;background:{{ bg }}"></div>
          {% else %}
            <div class="ns-bar" style="height:2px;background:#eee"></div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="divider"></div>

    {% comment %} Conditions {% endcomment %}
    <div class="flex flex--col gap--[3px]">
      <span class="label label--small">☀ ↓{{ data.sun.sets }} ↑{{ data.sun.rises }}{% if data.moon.sets %} · ☽ ↓{{ data.moon.sets }}{% endif %}</span>
      <span class="label label--small">🌡 {{ data.forecast.now.temp }}°C · 💧 {{ data.forecast.now.dew_point }}°C · 💨 {{ data.forecast.now.wind_dir }} {{ data.forecast.now.wind_speed }} km/h</span>
      <span class="label label--small">RH {{ data.forecast.now.humidity }}% · ☁ L{{ data.forecast.now.cloud_low }}% M{{ data.forecast.now.cloud_mid }}% H{{ data.forecast.now.cloud_high }}%</span>
    </div>

    <div class="divider"></div>

    {% comment %} 4-day moon forecast {% endcomment %}
    <div class="flex gap--[6px]">
      {% for day in data.moon.days %}
        <div class="flex flex--col gap--[2px] align--center" style="flex:1">
          <img class="{{ mf_class }}"
               data-illum="{{ day.illumination }}"
               data-waxing="{{ day.waxing }}"
               style="width:28px;height:28px" alt="{{ day.phase }}">
          <span class="label label--small" style="font-size:8px;text-align:center">{{ day.label }}</span>
          <span class="label label--small" style="font-size:8px;text-align:center">{{ day.illumination }}%</span>
        </div>
      {% endfor %}
    </div>

    <div class="divider"></div>

    {% comment %} Planets {% endcomment %}
    {% if data.planets.size > 0 %}
      <div class="flex flex--col gap--[3px]">
        {% for planet in data.planets limit: 4 %}
          <div class="flex gap--small">
            <span class="label label--small" style="flex:1;min-width:0">{{ planet.name }} {{ planet.dir }} {{ planet.alt }}°</span>
            <span class="label label--small" style="color:#555;flex-shrink:0">mag {{ planet.mag }} · {{ planet.constellation }}</span>
          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</div>

{% else %}

<div class="layout layout--col gap--small">

  {% if view == 2 %}

    <div class="flex gap--medium">
      <div class="flex flex--col gap--xsmall align--center" style="width:64px;flex-shrink:0">
        <img id="{{ moon_id }}" style="width:56px;height:56px" alt="moon">
        <span class="label label--small" style="text-align:center">{{ data.moon.illumination }}%</span>
        {% if data.moon.sets %}<span class="label label--small">↓ {{ data.moon.sets }}</span>{% endif %}
      </div>
      <div style="border-left:1px solid black;align-self:stretch;margin:0 8px;flex-shrink:0"></div>
      <div class="flex flex--col gap--xsmall" style="flex:1;min-width:0">
        <div class="flex gap--small align--center">
          <span class="title">{{ data.viewing.verdict }}</span>
          <span class="label">{{ data.viewing.stars_text }}</span>
        </div>
        <span class="label label--small">{{ data.moon.phase }} · Bortle {{ data.sky.bortle }} · NELM {{ data.sky.nelm }}</span>
        <span class="label label--small">☀ ↓{{ data.sun.sets }} ↑{{ data.sun.rises }} · ☁ {{ data.forecast.now.cloud }}% · 🌡 {{ data.forecast.now.temp }}°C 💨 {{ data.forecast.now.wind_dir }} {{ data.forecast.now.wind_speed }}</span>
        {% if data.planets.size > 0 %}
          <span class="label label--small">{% for planet in data.planets limit: 3 %}{{ planet.name }} {{ planet.dir }} {{ planet.alt }}° ({{ planet.mag }}){% unless forloop.last %} · {% endunless %}{% endfor %}</span>
        {% endif %}
      </div>
    </div>

  {% elsif view == 3 %}

    <div class="flex gap--small align--center">
      <img id="{{ moon_id }}" style="width:48px;height:48px;flex-shrink:0" alt="moon">
      <div class="flex flex--col gap--xsmall">
        <span class="title">{{ data.viewing.verdict }} {{ data.viewing.stars_text }}</span>
        <span class="label label--small">{{ data.moon.phase }} {{ data.moon.illumination }}% · Bortle {{ data.sky.bortle }}</span>
        <span class="label label--small">☀ ↓{{ data.sun.sets }} ↑{{ data.sun.rises }} · ☁ {{ data.forecast.now.cloud }}% · {{ data.forecast.now.temp }}°C</span>
      </div>
    </div>

  {% elsif view == 4 %}

    <div class="flex gap--small align--center">
      <img id="{{ moon_id }}" style="width:38px;height:38px;flex-shrink:0" alt="moon">
      <div class="flex flex--col gap--xsmall">
        <span class="label">{{ data.viewing.verdict }} {{ data.viewing.stars_text }}</span>
        <span class="label label--small">{{ data.moon.illumination }}% · ☁ {{ data.forecast.now.cloud }}%</span>
      </div>
    </div>

  {% endif %}

</div>

{% endif %}

<div class="title_bar">
  <img class="image" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='currentColor'%3E%3Cpath d='M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z'/%3E%3C/svg%3E" alt="Night Sky">
  <span class="title">{{ trmnl.plugin_settings.instance_name }} — {{ data.viewing.date }}</span>
</div>

<script>
(function() {
  var moonId  = '{{ moon_id }}';
  var mfClass = '{{ mf_class }}';

  function moonShape(illum, isWaxing, r, c) {
    if (illum <= 2)  return '<circle cx="'+c+'" cy="'+c+'" r="'+r+'" fill="black" stroke="black" stroke-width="2"/>';
    if (illum >= 98) return '<circle cx="'+c+'" cy="'+c+'" r="'+r+'" fill="white" stroke="black" stroke-width="2"/>';
    var frac = illum / 100;
    var ex = Math.round(r * Math.abs(1 - 2 * frac) * 10) / 10;
    var bs = isWaxing ? 1 : 0, ts = frac < 0.5 ? bs : (1 - bs);
    var d = 'M '+c+','+(c-r)+' A '+r+' '+r+' 0 0 '+bs+' '+c+','+(c+r)+' A '+ex+' '+r+' 0 0 '+ts+' '+c+','+(c-r)+' Z';
    return '<circle cx="'+c+'" cy="'+c+'" r="'+r+'" fill="black" stroke="black" stroke-width="2"/><path d="'+d+'" fill="white"/>';
  }

  function moonSrc(illum, isWaxing, r, c) {
    var size = c * 2;
    var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 '+size+' '+size+'">'+moonShape(illum, isWaxing, r, c)+'</svg>';
    return 'data:image/svg+xml;base64,' + btoa(svg);
  }

  var illum    = {{ data.moon.illumination | default: 0 }};
  var isWaxing = /Waxing|New Moon|First Quarter/.test({{ data.moon.phase | json }});

  var el = document.getElementById(moonId);
  if (el) el.src = moonSrc(illum, isWaxing, 38, 40);

  document.querySelectorAll('.' + mfClass).forEach(function(img) {
    var i = parseInt(img.getAttribute('data-illum') || '0');
    var w = img.getAttribute('data-waxing') === 'true';
    img.src = moonSrc(i, w, 24, 26);
  });
})();
</script>
{% endtemplate %}
