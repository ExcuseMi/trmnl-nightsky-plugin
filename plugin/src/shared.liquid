{% template main %}
<div class="layout layout--col gap--small">

  {% comment %} Verdict header {% endcomment %}
  <div class="flex gap--small align--center">
    <span class="title{% if view == 1 %} title--xlarge{% elsif view == 2 %} title--large{% endif %}" style="flex-shrink:0; line-height:1">{{ viewing.stars_text }}</span>
    <div class="flex flex--col gap--xsmall">
      <span class="title{% if view == 1 %} title--large{% endif %}">{{ viewing.verdict }} viewing</span>
      <span class="label label--small">Bortle {{ sky.bortle }} · {{ sky.bortle_label }}{% if view == 1 or view == 2 %} · NELM {{ sky.nelm }}{% endif %}</span>
      {% if view == 1 %}
        <span class="label label--small">~{{ sky.stars_formatted }} naked-eye stars visible</span>
      {% endif %}
    </div>
  </div>

  {% unless view == 4 %}

  {% comment %} Full view: 3-column grid {% endcomment %}
  {% if view == 1 %}
    <div class="grid grid--cols-3 gap--small">

      <div class="flex flex--col gap--xsmall">
        <span class="label label--underline">Moon</span>
        <span class="label">{{ moon.phase }}</span>
        <span class="label label--small">{{ moon.illumination }}% illuminated</span>
        {% if moon.rises %}<span class="label label--small">rises {{ moon.rises }}</span>{% endif %}
        {% if moon.sets  %}<span class="label label--small">sets {{ moon.sets }}</span>{% endif %}
      </div>

      <div class="flex flex--col gap--xsmall">
        <span class="label label--underline">Clouds</span>
        <span class="label">{{ clouds.now }}% now</span>
        <span class="label label--small">{{ clouds.next6h_avg }}% next 6 h</span>
      </div>

      <div class="flex flex--col gap--xsmall">
        <span class="label label--underline">Planets</span>
        {% if planets.size > 0 %}
          {% for planet in planets limit: 4 %}
            <span class="label label--small">{{ planet.name }} {{ planet.dir }} {{ planet.alt }}°</span>
          {% endfor %}
        {% else %}
          <span class="label label--small">None above horizon</span>
        {% endif %}
      </div>

    </div>

    {% if viewing.best_from %}
      <span class="label label--small">Best window starts {{ viewing.best_from }}</span>
    {% endif %}

  {% comment %} Half-horizontal: 2 columns, no planets {% endcomment %}
  {% elsif view == 2 %}
    <div class="flex gap--large">
      <div class="flex flex--col gap--xsmall" style="flex:1">
        <span class="label label--underline">Moon</span>
        <span class="label label--small">{{ moon.phase }} · {{ moon.illumination }}%</span>
        {% if moon.sets %}<span class="label label--small">sets {{ moon.sets }}</span>{% endif %}
      </div>
      <div class="flex flex--col gap--xsmall" style="flex:1">
        <span class="label label--underline">Clouds</span>
        <span class="label label--small">{{ clouds.now }}% now · {{ clouds.next6h_avg }}% next 6h</span>
      </div>
      <div class="flex flex--col gap--xsmall" style="flex:1">
        <span class="label label--underline">Planets</span>
        {% if planets.size > 0 %}
          {% for planet in planets limit: 2 %}
            <span class="label label--small">{{ planet.name }} {{ planet.dir }} {{ planet.alt }}°</span>
          {% endfor %}
        {% else %}
          <span class="label label--small">None</span>
        {% endif %}
      </div>
    </div>

  {% comment %} Half-vertical: stacked {% endcomment %}
  {% elsif view == 3 %}
    <div class="flex flex--col gap--xsmall">
      <span class="label label--underline">Moon</span>
      <span class="label label--small">{{ moon.phase }} · {{ moon.illumination }}%{% if moon.sets %} · sets {{ moon.sets }}{% endif %}</span>
    </div>
    <div class="flex flex--col gap--xsmall">
      <span class="label label--underline">Clouds</span>
      <span class="label label--small">{{ clouds.now }}% now · {{ clouds.next6h_avg }}% next 6 h</span>
    </div>

  {% endif %}

  {% endunless %}

</div>
<div class="title_bar">
  <img class="image" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='currentColor'%3E%3Cpath d='M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z'/%3E%3C/svg%3E" alt="Night Sky">
  <span class="title">{{ trmnl.plugin_settings.instance_name }}</span>
</div>
{% endtemplate %}
