{% template main %}
{% assign moon_id = "moon-" | append_random %}
<div class="layout layout--col gap--small">

  {% if view == 1 %}

    {% comment %} ── Header ── {% endcomment %}
    <div class="flex gap--medium align--center">
      <span class="title title--xlarge" style="line-height:1;flex-shrink:0">{{ viewing.stars_text }}</span>
      <div class="flex flex--col gap--xsmall">
        <span class="title title--large">{{ viewing.verdict }} viewing</span>
        <span class="label label--small">Bortle {{ sky.bortle }} · {{ sky.bortle_label }} · NELM {{ sky.nelm }} · ~{{ sky.stars_formatted }} stars</span>
      </div>
    </div>

    <div style="border-top:2px solid black;flex-shrink:0"></div>

    {% comment %} ── Middle row: Moon | Sun + Clouds ── {% endcomment %}
    <div class="flex gap--none">

      <div class="flex flex--col gap--xsmall align--center" style="width:110px;flex-shrink:0">
        <img id="{{ moon_id }}" style="width:90px;height:90px" alt="moon">
        <span class="label label--small" style="text-align:center">{{ moon.phase }}</span>
        <span class="label label--small">{{ moon.illumination }}%</span>
        {% if moon.rises %}<span class="label label--small">↑ {{ moon.rises }}</span>{% endif %}
        {% if moon.sets  %}<span class="label label--small">↓ {{ moon.sets }}</span>{% endif %}
      </div>

      <div style="border-left:1px solid black;margin:0 14px;flex-shrink:0"></div>

      <div class="flex gap--medium" style="flex:1;min-width:0">

        <div class="flex flex--col gap--xsmall" style="width:90px;flex-shrink:0">
          <span class="label label--underline">Sun</span>
          {% if sun.sets  %}<span class="label label--small">↓ {{ sun.sets }}</span>{% endif %}
          {% if sun.rises %}<span class="label label--small">↑ {{ sun.rises }}</span>{% endif %}
        </div>

        <div style="border-left:1px solid black;margin:0 6px;flex-shrink:0"></div>

        <div class="flex flex--col gap--xsmall" style="flex:1;min-width:0">
          <span class="label label--underline">Clouds</span>
          {% if clouds.hourly.size > 0 %}
            <div class="flex gap--[4px] align--end" style="height:36px">
              {% for val in clouds.hourly %}
                {% assign bar_h = val | times: 36 | divided_by: 100 %}
                <div style="background:black;width:14px;min-height:2px;height:{{ bar_h }}px"></div>
              {% endfor %}
            </div>
          {% endif %}
          <span class="label label--small">{{ clouds.now }}% now · {{ clouds.next6h_avg }}% next 6 h</span>
        </div>

      </div>
    </div>

    <div style="border-top:1px solid black;flex-shrink:0"></div>

    {% comment %} ── Planets ── {% endcomment %}
    <div class="flex flex--col gap--xsmall">
      <span class="label label--underline">Planets above horizon</span>
      {% if planets.size > 0 %}
        <div class="grid grid--cols-2 gap--xsmall">
          {% for planet in planets limit: 6 %}
            <div class="flex flex--col gap--[2px]">
              <span class="label label--small">{{ planet.name }} {{ planet.dir }} {{ planet.alt }}°</span>
              <span class="label label--small">mag {{ planet.mag }} · {{ planet.size }}" · {{ planet.constellation }}</span>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <span class="label label--small">None above horizon right now</span>
      {% endif %}
    </div>

    {% if viewing.best_from %}
      <div style="border-top:1px solid black;flex-shrink:0"></div>
      <span class="label label--small">Best window starts {{ viewing.best_from }}</span>
    {% endif %}

  {% elsif view == 2 %}

    <div class="flex gap--medium">
      <div class="flex flex--col gap--xsmall align--center" style="width:64px;flex-shrink:0">
        <img id="{{ moon_id }}" style="width:56px;height:56px" alt="moon">
        <span class="label label--small" style="text-align:center">{{ moon.illumination }}%</span>
        {% if moon.sets %}<span class="label label--small">↓ {{ moon.sets }}</span>{% endif %}
      </div>
      <div style="border-left:1px solid black;align-self:stretch;margin:0 8px;flex-shrink:0"></div>
      <div class="flex flex--col gap--xsmall" style="flex:1;min-width:0">
        <div class="flex gap--small align--center">
          <span class="title">{{ viewing.verdict }}</span>
          <span class="label">{{ viewing.stars_text }}</span>
        </div>
        <span class="label label--small">{{ moon.phase }} · Bortle {{ sky.bortle }} · NELM {{ sky.nelm }}</span>
        <span class="label label--small">☀ ↓ {{ sun.sets }} ↑ {{ sun.rises }} · ☁ {{ clouds.now }}%</span>
        {% if planets.size > 0 %}
          <span class="label label--small">{% for planet in planets limit: 3 %}{{ planet.name }} {{ planet.dir }} {{ planet.alt }}° ({{ planet.mag }}){% unless forloop.last %} · {% endunless %}{% endfor %}</span>
        {% endif %}
      </div>
    </div>

  {% elsif view == 3 %}

    <div class="flex gap--small align--center">
      <img id="{{ moon_id }}" style="width:48px;height:48px;flex-shrink:0" alt="moon">
      <div class="flex flex--col gap--xsmall">
        <span class="title">{{ viewing.verdict }} {{ viewing.stars_text }}</span>
        <span class="label label--small">{{ moon.phase }} {{ moon.illumination }}% · Bortle {{ sky.bortle }}</span>
        <span class="label label--small">☀ ↓ {{ sun.sets }} ↑ {{ sun.rises }} · ☁ {{ clouds.now }}%</span>
      </div>
    </div>

  {% elsif view == 4 %}

    <div class="flex gap--small align--center">
      <img id="{{ moon_id }}" style="width:38px;height:38px;flex-shrink:0" alt="moon">
      <div class="flex flex--col gap--xsmall">
        <span class="label">{{ viewing.verdict }} {{ viewing.stars_text }}</span>
        <span class="label label--small">{{ moon.illumination }}% · ☁ {{ clouds.now }}%</span>
      </div>
    </div>

  {% endif %}

</div>
<div class="title_bar">
  <img class="image" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='currentColor'%3E%3Cpath d='M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z'/%3E%3C/svg%3E" alt="Night Sky">
  <span class="title">{{ trmnl.plugin_settings.instance_name }} — {{ viewing.date }}</span>
</div>

<script>
(function() {
  var illum = {{ moon.illumination | default: 0 }};
  var phase = {{ moon.phase | json }};
  var r = 38, c = 40, shape;

  if (illum <= 2) {
    shape = '<circle cx="' + c + '" cy="' + c + '" r="' + r + '" fill="black" stroke="black" stroke-width="2"/>';
  } else if (illum >= 98) {
    shape = '<circle cx="' + c + '" cy="' + c + '" r="' + r + '" fill="white" stroke="black" stroke-width="2"/>';
  } else {
    var isWaxing = /Waxing|New Moon|First Quarter/.test(phase);
    var frac = illum / 100;
    var ex   = Math.round(r * Math.abs(1 - 2 * frac) * 10) / 10;
    var bs   = isWaxing ? 1 : 0;
    var ts   = frac < 0.5 ? bs : (1 - bs);
    var d    = 'M ' + c + ',' + (c - r) +
               ' A ' + r + ' ' + r + ' 0 0 ' + bs + ' ' + c + ',' + (c + r) +
               ' A ' + ex + ' ' + r + ' 0 0 ' + ts + ' ' + c + ',' + (c - r) + ' Z';
    shape = '<circle cx="' + c + '" cy="' + c + '" r="' + r + '" fill="black" stroke="black" stroke-width="2"/>' +
            '<path d="' + d + '" fill="white"/>';
  }

  var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 80">' + shape + '</svg>';
  var el = document.getElementById('{{ moon_id }}');
  if (el) el.src = 'data:image/svg+xml;base64,' + btoa(svg);
})();
</script>
{% endtemplate %}
