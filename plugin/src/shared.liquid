{% template main %}
{% assign moon_id = "moon-" | append_random %}
<div class="layout layout--col gap--small">

  {% if view == 1 %}
    <div class="flex gap--medium stretch-y">

      <div class="flex flex--col gap--xsmall align--center" style="width:100px;flex-shrink:0">
        <img id="{{ moon_id }}" style="width:90px;height:90px" alt="moon">
        <span class="label label--small" style="text-align:center">{{ moon.phase }}</span>
        <span class="label label--small" style="text-align:center">{{ moon.illumination }}%</span>
        {% if moon.rises %}<span class="label label--small">↑ {{ moon.rises }}</span>{% endif %}
        {% if moon.sets  %}<span class="label label--small">↓ {{ moon.sets }}</span>{% endif %}
      </div>

      <div class="flex flex--col gap--small" style="flex:1;min-width:0">
        <div class="flex flex--col gap--xsmall">
          <div class="flex gap--small align--center">
            <span class="title title--large">{{ viewing.verdict }}</span>
            <span class="title">{{ viewing.stars_text }}</span>
          </div>
          <span class="label label--small">Bortle {{ sky.bortle }} · {{ sky.bortle_label }} · NELM {{ sky.nelm }}</span>
          <span class="label label--small">~{{ sky.stars_formatted }} naked-eye stars</span>
        </div>

        <div class="flex flex--col gap--xsmall">
          <span class="label label--underline">Clouds</span>
          {% if clouds.hourly.size > 0 %}
            <div class="flex gap--[3px] align--end" style="height:28px">
              {% for val in clouds.hourly %}
                {% assign bar_h = val | times: 28 | divided_by: 100 %}
                <div style="background:black;width:12px;min-height:2px;height:{{ bar_h }}px"></div>
              {% endfor %}
            </div>
          {% endif %}
          <span class="label label--small">{{ clouds.now }}% now · {{ clouds.next6h_avg }}% next 6 h</span>
        </div>

        <div class="flex flex--col gap--xsmall">
          <span class="label label--underline">Planets above horizon</span>
          {% if planets.size > 0 %}
            {% for planet in planets limit: 4 %}
              <span class="label label--small">{{ planet.name }} {{ planet.dir }} {{ planet.alt }}°</span>
            {% endfor %}
          {% else %}
            <span class="label label--small">None above horizon right now</span>
          {% endif %}
        </div>

        {% if viewing.best_from %}
          <span class="label label--small">Best window starts {{ viewing.best_from }}</span>
        {% endif %}
      </div>
    </div>

  {% elsif view == 2 %}
    <div class="flex gap--medium">
      <div class="flex flex--col gap--xsmall align--center" style="width:70px;flex-shrink:0">
        <img id="{{ moon_id }}" style="width:60px;height:60px" alt="moon">
        <span class="label label--small" style="text-align:center">{{ moon.illumination }}%</span>
        {% if moon.sets %}<span class="label label--small">↓ {{ moon.sets }}</span>{% endif %}
      </div>
      <div class="flex flex--col gap--xsmall" style="flex:1;min-width:0">
        <div class="flex gap--small align--center">
          <span class="title">{{ viewing.verdict }}</span>
          <span class="label">{{ viewing.stars_text }}</span>
        </div>
        <span class="label label--small">Bortle {{ sky.bortle }} · {{ sky.bortle_label }} · NELM {{ sky.nelm }}</span>
        <span class="label label--small">Clouds {{ clouds.now }}% now · {{ clouds.next6h_avg }}% next 6h</span>
        {% if planets.size > 0 %}
          <span class="label label--small">{% for planet in planets limit: 3 %}{{ planet.name }} {{ planet.alt }}°{% unless forloop.last %} · {% endunless %}{% endfor %}</span>
        {% endif %}
      </div>
    </div>

  {% elsif view == 3 %}
    <div class="flex gap--small align--center">
      <img id="{{ moon_id }}" style="width:50px;height:50px;flex-shrink:0" alt="moon">
      <div class="flex flex--col gap--xsmall">
        <span class="title">{{ viewing.verdict }} {{ viewing.stars_text }}</span>
        <span class="label label--small">Bortle {{ sky.bortle }} · {{ sky.bortle_label }}</span>
        <span class="label label--small">{{ moon.phase }} {{ moon.illumination }}% · clouds {{ clouds.now }}%</span>
      </div>
    </div>

  {% elsif view == 4 %}
    <div class="flex gap--small align--center">
      <img id="{{ moon_id }}" style="width:40px;height:40px;flex-shrink:0" alt="moon">
      <div class="flex flex--col gap--xsmall">
        <span class="label">{{ viewing.verdict }} {{ viewing.stars_text }}</span>
        <span class="label label--small">{{ moon.illumination }}% · {{ clouds.now }}%☁</span>
      </div>
    </div>

  {% endif %}

</div>
<div class="title_bar">
  <img class="image" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='currentColor'%3E%3Cpath d='M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z'/%3E%3C/svg%3E" alt="Night Sky">
  <span class="title">{{ trmnl.plugin_settings.instance_name }}</span>
</div>

<script>
(function() {
  var illum = {{ moon.illumination | default: 0 }};
  var phase = {{ moon.phase | json }};
  var r = 38, c = 40, shape;

  if (illum <= 2) {
    shape = '<circle cx="' + c + '" cy="' + c + '" r="' + r + '" fill="black" stroke="black" stroke-width="2"/>';
  } else if (illum >= 98) {
    shape = '<circle cx="' + c + '" cy="' + c + '" r="' + r + '" fill="white" stroke="black" stroke-width="2"/>';
  } else {
    var isWaxing = /Waxing|New Moon|First Quarter/.test(phase);
    var frac = illum / 100;
    var ex   = Math.round(r * Math.abs(1 - 2 * frac) * 10) / 10;
    var bs   = isWaxing ? 1 : 0;
    var ts   = frac < 0.5 ? bs : (1 - bs);
    var d    = 'M ' + c + ',' + (c - r) +
               ' A ' + r + ' ' + r + ' 0 0 ' + bs + ' ' + c + ',' + (c + r) +
               ' A ' + ex + ' ' + r + ' 0 0 ' + ts + ' ' + c + ',' + (c - r) + ' Z';
    shape = '<circle cx="' + c + '" cy="' + c + '" r="' + r + '" fill="black" stroke="black" stroke-width="2"/>' +
            '<path d="' + d + '" fill="white"/>';
  }

  var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 80">' + shape + '</svg>';
  var src = 'data:image/svg+xml;base64,' + btoa(svg);
  var el = document.getElementById('{{ moon_id }}');
  if (el) el.src = src;
})();
</script>
{% endtemplate %}
