# Backend
BACKEND_PORT=8080

# Redis (defaults to the docker-compose service)
REDIS_URL=redis://redis:6379

# Public base URL of this backend (used to build chart image URLs).
# Required when running behind a reverse proxy that strips a path prefix.
# Example: https://trmnl.bettens.dev/nightsky
BASE_URL=

# Access control:
#   whitelist_only — TRMNL IPs only (default, production)
#   rate_limited   — TRMNL unrestricted; public callers limited to 1 request per window
#   open           — no restrictions (local dev)
ACCESS_MODE=rate_limited
IP_REFRESH_HOURS=24
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=300
