# Backend
BACKEND_PORT=8080

# Redis (defaults to the docker-compose service)
REDIS_URL=redis://redis:6379

# Public base URL of this backend (used to build chart image URLs).
# Required when running behind a reverse proxy that strips a path prefix.
# Example: https://trmnl.bettens.dev/nightsky
BASE_URL=

# Set false for local dev so trmnlp serve / curl work without IP check
ENABLE_IP_WHITELIST=true
IP_REFRESH_HOURS=24
